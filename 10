nums = list(map(int, input().split()))
n = len(nums)
triplets_set = set()

for i in range(n):
    for j in range(i + 1, n):
        for k in range(j + 1, n):
            if nums[i] + nums[j] + nums[k] == 0:
                triplets_set.add(tuple(sorted([nums[i], nums[j], nums[k]])))

print([list(t) for t in sorted(triplets_set)])
